# ── ZoikoMeds environment ──────────────────────────────────────────────
# Copy to .env.local and adjust as needed.

# Backend platform API (ZoikoMeds API — see ZoikoMeds.postman_collection.json)
NEXT_PUBLIC_API_URL=https://zoiko-meds-platform.onrender.com/api

# The authenticated frontend app (login, dashboards, portals)
NEXT_PUBLIC_APP_URL=https://zoiko-meds-platform.vercel.app

# Server-only keys (used by /app/api/medicine/* routes — not exposed to the client)
# ANTHROPIC_API_KEY=
